---
//tools
import { Image } from 'astro:assets';

//component
import MyForm from '../components/contact_form.astro';


//asset
import linkedin from '../icons/linkedin.png';
---

<div class="bg-gradient-to-r from-left to-right text-white py-6" id="contactSection">
    <section class="max-w-5xl mx-auto font-bold px-4 lg:p-0">
        <div class="flex justify-end">
            <h1 class="text-5xl">Get In Touch</h1>
        </div>

        <section class="grid md:grid-cols-2 gap-4 mt-12">
            <article>
                <article class="px-4 py-3 bg-white/5 backdrop-blur border border-white/10 rounded-xl max-w-96 shadow-md mb-6">
                    <p class="text-slate-300 text-sm">Contact us today to explore how we can transform your business through technology.</p>
                </article>
                <MyForm/>
            </article>

            <article class="grid lg:grid-cols-2 gap-8 h-80">
                <section class="mx-auto ">
                    <h3 class="text-2xl my-4 text-slate-400">Telephone</h3>
                    <div class="my-2">
                        <p>Brewell Ncita - CEO</p>
                        <p class="text-sm ">+27 84 890 0029</p>
                    </div>
                    <div class=" my-2">
                        <p>Kevin Chiloane - CTO</p>
                        <p class="text-sm ">+27 68 505 5129</p>
                        <p class="text-sm text-cyan-400 hover:text-white transition-colors mt-1"><a href="mailto:kevin@okwethuTech.com">kevin@okwethuTech.com</a></p>
                    </div>
                </section>
                <section class="mx-auto w-[150px]">
                    <h3 class="text-2xl my-4 text-slate-400">Socials</h3>
                    <div class="">
                        <a href="https://www.linkedin.com/company/okwethu-tech/" target="_blank"><Image alt="linkedIn" src={linkedin} format='avif' width='34'/></a>
                    </div>
                </section>
                
            </article>
        </section>
    </section>
</div>