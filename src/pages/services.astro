---
import PagesLayout from "../layout/PagesLayout.astro";
import { Image } from 'astro:assets';

import webs from '../assets/webss.svg';
import combination from '../assets/combination.svg';

const pageTitle = 'OkwethuTech - Services';
---

<PagesLayout title={pageTitle}>
    <section class="min-h-screen py-20 px-4 max-w-6xl mx-auto">
        <!-- Hero Section for Services -->
        <div class="text-center mb-20 animate-fade-in-up">
            <h1 class="text-5xl md:text-6xl font-extrabold mb-6 text-transparent bg-clip-text bg-gradient-to-r from-left-card to-right-card">
                Discover Our Services
            </h1>
            <p class="text-lg md:text-xl max-w-2xl mx-auto text-slate-300">
                Crafting bespoke technology solutions tailored to the unique needs of South African businesses of all sizes.
            </p>
        </div>

        <!-- Services Grid -->
        <div class="grid lg:grid-cols-2 gap-10">
            <!-- Card 1: Custom Engineered Software -->
            <article class="group relative rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 p-8 hover:bg-white/10 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_20px_50px_rgba(9,98,98,0.3)]">
                <div class="absolute inset-0 bg-gradient-to-br from-left-card/20 to-transparent rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                
                <div class="flex flex-col md:flex-row items-center gap-8 relative z-10">
                    <figure class="w-48 shrink-0">
                        <div class="p-4 bg-black/40 rounded-full border border-white/5 shadow-inner">
                            <Image alt='Web Applications Illustration' src={webs} format='avif' class="w-full h-auto drop-shadow-md transition-transform group-hover:scale-105 duration-300"/>
                        </div>
                    </figure>
                    <div>
                        <h2 class="text-2xl font-bold text-white mb-4">Custom Engineered Software</h2>
                        <p class="text-slate-300 leading-relaxed text-sm md:text-base">
                            We specialise in developing innovative <strong class="text-green-400">Web Applications</strong>, designing <strong class="text-green-400">Dynamic Websites</strong>, crafting user-friendly <strong class="text-green-400">Mobile Applications</strong> and implementing a sophisticated <strong class="text-green-400">Content Management System</strong> (CMS) designed to scale with your business growth.
                        </p>
                    </div>
                </div>
            </article>

            <!-- Card 2: Systems Integration -->
            <article class="group relative rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 p-8 hover:bg-white/10 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_20px_50px_rgba(8,145,178,0.3)]">
                <div class="absolute inset-0 bg-gradient-to-bl from-right-card/20 to-transparent rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                
                <div class="flex flex-col md:flex-row items-center gap-8 relative z-10">
                    <figure class="w-48 shrink-0 md:order-last">
                        <div class="p-4 bg-black/40 rounded-full border border-white/5 shadow-inner">
                            <Image alt='Systems Integration Illustration' src={combination} format='avif' class="w-full h-auto drop-shadow-md transition-transform group-hover:scale-105 duration-300"/>
                        </div>
                    </figure>
                    <div>
                        <h2 class="text-2xl font-bold text-white mb-4">Systems Integration</h2>
                        <p class="text-slate-300 leading-relaxed text-sm md:text-base">
                            Our comprehensive suite of services includes <strong class="text-green-400">Strategic Consulting</strong>, <strong class="text-green-400">Systems Integration</strong>, and ongoing <strong class="text-green-400">Support</strong>, ensuring that your digital ecosystem remains efficient, adaptable, and ahead of the curve.
                        </p>
                    </div>
                </div>
            </article>
        </div>
        
        <div class="mt-20 text-center">
            <a href="/get_in_touch" class="inline-block bg-gradient-to-r from-left-card to-right-card text-white font-bold py-3 px-8 rounded-full hover:scale-105 transition-transform duration-300 shadow-lg hover:shadow-cyan-500/25">
                Let's Build It
            </a>
        </div>
    </section>
</PagesLayout>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in-up {
        animation: fadeInUp 0.8s ease-out forwards;
    }
</style>
