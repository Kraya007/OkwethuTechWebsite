---
import PagesLayout from "../layout/PagesLayout.astro";

import MyForm from '../components/contact_form.astro';

const pageTitle = 'OkwethuTech - Contact Us'

---

<PagesLayout title = {pageTitle}>
    <div>
        <section class="max-w-5xl mx-auto py-8 px-4 lg:px-0">
            <article class="text-center my-4">
                <h2 class="text-2xl mb-12 font-bold">Get In Touch</h2>
                <p class="text-xl">
                    Join us on this exciting journey of technological advancement. Together, let's harness the power of local innovation to shape a brighter future for South African businesses. Experience the OKWETHU Tech difference - where your success is truly "Okwethu" ~ ours.
                </p>
            </article>

            <article class="grid md:grid-cols-2 place-content-center mt-20 pt-20 border-t-2">
                <div class="flex justify-center py-4">
                    <h3 class="text-7xl text-center">IT STARTS HERE</h3>
                </div>
                <MyForm/>
            </article>
            
        </section>
    </div>
</PagesLayout>


